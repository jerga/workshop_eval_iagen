# LLM (OpenAI-compatible endpoint uniquement)
LLM_API_BASE=https://api.mistral.ai/v1
LLM_API_KEY=
LLM_MODEL=mistral-small-latest
LLM_PROVIDER=openai_compatible
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024

# Embeddings (OpenAI-compatible endpoint uniquement)
EMBEDDING_API_BASE=https://api.mistral.ai/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=mistral-embed
EMBEDDING_PROVIDER=openai_compatible

# Langfuse
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Workshop
WORKSHOP_DEBUG=false

# Disable telemetry
DEEPEVAL_TELEMETRY_OPT_OUT=1

# Custom throttling for LLM calls (in seconds)
DEEPEVAL_LLM_MIN_INTERVAL_S=0
